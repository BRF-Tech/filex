# Copy to .env, fill in, then:
#   docker compose -f docker-compose.full.yml --env-file .env up -d
#
# DNS: point every ENABLED domain below at this host's public IP. Ports 80 +
# 443 must be open so Caddy can obtain HTTPS certificates.

# ── Which add-ons to run ────────────────────────────────────────────────
# Comma list of Compose profiles. Remove one to turn that add-on off (and also
# blank its FILEX_*_URL below). Available: onlyoffice, drawio, convert, minio.
# Mermaid needs nothing here — filex renders it in the browser.
COMPOSE_PROFILES=onlyoffice,drawio,minio

# ── Domains ─────────────────────────────────────────────────────────────
FILEX_DOMAIN=files.example.com
ONLYOFFICE_DOMAIN=office.example.com      # only if the onlyoffice profile is on
DRAWIO_DOMAIN=draw.example.com            # only if the drawio profile is on
MINIO_CONSOLE_DOMAIN=minio.example.com    # only if the minio profile is on

# ── External integration URLs (filex → the add-on) ──────────────────────
# Set the ones you enabled; leave the rest blank. A blank/unreachable URL
# makes filex hide that integration in the UI.
FILEX_ONLYOFFICE_URL=https://office.example.com
FILEX_DRAWIO_URL=https://draw.example.com
FILEX_CONVERT_URL=                        # e.g. https://files.example.com/convert (convert profile)

# Optional: override the convert add-on image (default is our published
# p2r3/convert fork; see docs/CONVERT-INTEGRATION.md).
# CONVERT_IMAGE=ghcr.io/brf-tech/converter-filex:latest

# ── Zero-touch config (seeded on first boot; all optional) ──────────────
# Filled-in values are applied to the DB once, on first boot — so the stack
# comes up configured with no admin-UI clicks. Later UI edits win.

# SSO / OIDC — set the driver + these four and you have working SSO.
# FILEX_AUTH_DRIVERS=local,oidc
# FILEX_OIDC_ISSUER=https://id.example.com/realms/main
# FILEX_OIDC_CLIENT_ID=filex
# FILEX_OIDC_CLIENT_SECRET=change-me-oidc
# FILEX_OIDC_ADMIN_GROUP=filex-admin
# FILEX_OIDC_ROLE_CLAIM=realm_access.roles
# (redirect defaults to https://FILEX_DOMAIN/api/auth/oidc/callback)

# First admin (else a random admin@local is printed once in the logs).
# FILEX_ADMIN_EMAIL=admin@example.com
# FILEX_ADMIN_PASSWORD=change-me-admin

# SMTP for share/invite email.
# FILEX_SMTP_HOST=smtp.example.com
# FILEX_SMTP_PORT=587
# FILEX_SMTP_USERNAME=apikey
# FILEX_SMTP_PASSWORD=change-me-smtp
# FILEX_SMTP_FROM=no-reply@example.com
# FILEX_SMTP_TLS=starttls

# Branding + trash.
# FILEX_SITE_NAME=Acme Files
# FILEX_TRASH_RETENTION_DAYS=30

# Default storage — where files live. Default = a local folder (./files).
# Pick ONE of the options below (or leave the default). You can always add more
# storages later in the admin UI (Storages -> Add).

# --- Option A: the bundled MinIO (keep the minio profile on) -------------
# FILEX_DEFAULT_STORAGE_DRIVER=s3
# FILEX_DEFAULT_STORAGE_S3_BUCKET=filex
# FILEX_DEFAULT_STORAGE_S3_ENDPOINT=http://minio:9000
# FILEX_DEFAULT_STORAGE_S3_ACCESS_KEY=filex
# FILEX_DEFAULT_STORAGE_S3_SECRET_KEY=change-me-minio-password-min-8-chars

# --- Option B: YOUR existing S3 bucket (AWS / Hetzner / R2 / Backblaze) ---
# FILEX_DEFAULT_STORAGE_DRIVER=s3
# FILEX_DEFAULT_STORAGE_S3_BUCKET=my-bucket
# FILEX_DEFAULT_STORAGE_S3_PREFIX=filex          # a sub-folder (never the root)
# FILEX_DEFAULT_STORAGE_S3_ENDPOINT=https://s3.eu-central-1.amazonaws.com
# FILEX_DEFAULT_STORAGE_S3_REGION=eu-central-1
# FILEX_DEFAULT_STORAGE_S3_ACCESS_KEY=AKIA...
# FILEX_DEFAULT_STORAGE_S3_SECRET_KEY=...

# --- Option C: YOUR SFTP / NAS server -----------------------------------
# FILEX_DEFAULT_STORAGE_DRIVER=sftp
# FILEX_DEFAULT_STORAGE_CONFIG={"host":"nas.example.com","port":22,"user":"filex","password":"s3cret","root":"/srv/files"}

# --- Option D: YOUR WebDAV server (Nextcloud, etc.) ----------------------
# FILEX_DEFAULT_STORAGE_DRIVER=webdav
# FILEX_DEFAULT_STORAGE_CONFIG={"url":"https://dav.example.com/remote.php/dav/files/me","user":"me","password":"app-password","root":"filex"}

# ── Secrets — CHANGE ALL OF THESE ───────────────────────────────────────
# Generate strong values, e.g.:  openssl rand -hex 24

# PostgreSQL password (filex's database user).
POSTGRES_PASSWORD=change-me-postgres-password

# Shared OnlyOffice JWT secret — filex and the Document Server MUST use the
# exact same value (it's the whole trust relationship between them).
ONLYOFFICE_JWT_SECRET=change-me-onlyoffice-shared-secret

# MinIO root credentials (also used as the S3 access/secret when you add the
# bundled MinIO as a storage in the admin UI).
MINIO_ROOT_USER=filex
MINIO_ROOT_PASSWORD=change-me-minio-password-min-8-chars
