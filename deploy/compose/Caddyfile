# Caddy config for the full filex stack. HTTPS is obtained + renewed
# automatically for real public domains (ports 80/443 must be reachable).
#
# Add-on vhosts (OnlyOffice / Drawio / MinIO) below default to a harmless
# *.localhost self-signed host when you don't run that add-on. Leave the block
# or delete it — an unused *.localhost vhost costs nothing and requests no cert.

{$FILEX_DOMAIN} {
	encode zstd gzip
	# Large uploads: for S3 only the init/finalize JSON transits the proxy
	# (multipart PUTs go browser→S3 directly); local/SFTP uploads stream through.
	request_body {
		max_size 5GB
	}

	# Universal converter (convert profile) is served under /convert.
	@convert path /convert /convert/*
	handle @convert {
		reverse_proxy convert:80
	}

	# Everything else → filex. WebSocket/SSE (e.g. /api/ai/mcp) upgrades itself.
	handle {
		reverse_proxy filex:5212 {
			header_up X-Real-IP {remote_host}
		}
	}
}

# OnlyOffice Document Server (onlyoffice profile). The browser loads its iframe
# from here and filex calls it server-to-server, so it needs a real HTTPS host.
# Delete this block if you don't run OnlyOffice.
{$ONLYOFFICE_DOMAIN} {
	reverse_proxy onlyoffice:80
}

# Drawio / diagrams.net editor (drawio profile) — embedded as an iframe, so it
# needs a real HTTPS host. Delete this block if you don't run Drawio.
{$DRAWIO_DOMAIN} {
	reverse_proxy drawio:8080
}

# MinIO web console (minio profile) — bucket management UI. Delete this block if
# you don't want the console exposed.
{$MINIO_CONSOLE_DOMAIN} {
	reverse_proxy minio:9001
}
