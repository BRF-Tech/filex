# filex full image (~250 MB) — slim base + ffmpeg, ghostscript, libreoffice for full thumbnail support
FROM ghcr.io/brf-tech/filex:slim
USER root
RUN apk --no-cache add \
    ffmpeg \
    vips-tools \
    ghostscript \
    libreoffice \
    openjdk17-jre-headless \
    poppler-utils \
    fonts-liberation \
    fonts-dejavu
