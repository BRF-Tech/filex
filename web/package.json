{
  "name": "@brftech/filex-admin",
  "private": true,
  "version": "0.1.2",
  "type": "module",
  "description": "filex admin UI — Vue 3 SPA embedded into the Go binary via go:embed",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "type-check": "vue-tsc --noEmit",
    "clean": "rimraf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:headed": "cypress run --headed --no-exit"
  },
  "dependencies": {
    "@brftech/filex-core": "workspace:*",
    "@headlessui/vue": "^1.7.23",
    "axios": "^1.7.7",
    "lucide-vue-next": "^0.453.0",
    "pinia": "^2.2.4",
    "vue": "^3.5.12",
    "vue-i18n": "^9.14.0",
    "vue-router": "^4.4.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^22.7.0",
    "@vitejs/plugin-vue": "^5.1.4",
    "@vitest/coverage-v8": "^2.1.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.5.1",
    "autoprefixer": "^10.4.20",
    "cypress": "13",
    "eslint": "^9.13.0",
    "eslint-plugin-vue": "^9.29.0",
    "happy-dom": "^15.7.4",
    "postcss": "^8.4.47",
    "rimraf": "^6.0.1",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.12.0",
    "vite": "^5.4.10",
    "vitest": "^2.1.4",
    "vue-tsc": "^2.1.10"
  }
}
