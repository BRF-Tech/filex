{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["@playwright/test", "node"],
    "noEmit": true
  },
  "include": ["tests/**/*", "helpers/**/*", "playwright.config.ts"]
}
