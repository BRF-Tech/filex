# filex docker-compose .env example.
# Copy to .env and edit. Anything you leave commented falls back to safe defaults.

# ============================================================================
# Core filex
# ============================================================================
# FILEX_IMAGE=ghcr.io/brf-tech/filex:latest
# FILEX_FULL_IMAGE=ghcr.io/brf-tech/filex:full
# FILEX_PORT=5212
# FILEX_PUBLIC_URL=http://localhost:5212

# Auth: comma list of: local, oidc, ldap, proxy_header
# FILEX_AUTH_DRIVERS=local

# OIDC (only used when 'oidc' is in FILEX_AUTH_DRIVERS)
# FILEX_OIDC_ISSUER=https://auth.example.com/realms/main
# FILEX_OIDC_CLIENT_ID=filex
# FILEX_OIDC_CLIENT_SECRET=changeme
# FILEX_OIDC_REDIRECT_URL=https://files.example.com/api/auth/oidc/callback
# SSO-first login: the login page redirects straight to the IdP; the password
# form stays reachable via /admin/login?local=1 (break-glass admin@local).
# FILEX_OIDC_AUTO_REDIRECT=false

# Share the session cookie across subdomains (Domain attribute on
# filex_session). Empty = host-only cookie (default).
# FILEX_COOKIE_DOMAIN=.example.com

# DB driver: sqlite | mysql | postgres
# FILEX_DB_DRIVER=sqlite
# FILEX_DB_DSN=/data/filex.db
# Postgres example:
# FILEX_DB_DRIVER=postgres
# FILEX_DB_DSN=postgres://filex:changeme@postgres:5432/filex?sslmode=disable

# Default storage driver for new installs (admin can add more later)
# FILEX_DEFAULT_STORAGE_DRIVER=local

# Thumbnails (true requires the 'full' image or matching tools on host)
# FILEX_THUMBS_ENABLED=false

# ============================================================================
# OnlyOffice (profile: onlyoffice)
# ============================================================================
# Same secret on both sides!
# ONLYOFFICE_JWT_SECRET=please-change-me-shared-with-filex
# FILEX_ONLYOFFICE_URL=http://onlyoffice
# FILEX_ONLYOFFICE_JWT=please-change-me-shared-with-filex
# ONLYOFFICE_PORT=8099

# ============================================================================
# PostgreSQL (profile: postgres)
# ============================================================================
# POSTGRES_USER=filex
# POSTGRES_PASSWORD=changeme
# POSTGRES_DB=filex
# POSTGRES_PORT=5432

# ============================================================================
# MinIO (profile: minio)
# ============================================================================
# MINIO_USER=filex
# MINIO_PASSWORD=changeme-very-long
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# ============================================================================
# Drawio (no compose service; just point at a public/self-hosted instance)
# ============================================================================
# FILEX_DRAWIO_URL=https://embed.diagrams.net
